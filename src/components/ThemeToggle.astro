---
import { Icon } from 'astro-icon/components';
---

<button class="theme-toggle group relative inline-flex items-center justify-center w-8 h-8 cursor-pointer" aria-label="Toggle Theme">
  <Icon
    name="bx:sun"
    class="absolute inset-0 m-auto w-7 h-7 text-primary-light group-hover:text-green-700 transition-all duration-300 ease-in-out opacity-100 dark:opacity-0 pointer-events-none"
  />
  <Icon
    name="bx:moon"
    class="absolute inset-0 m-auto w-7 h-7 text-primary-dark group-hover:text-pastel-blue-200 transition-all duration-300 ease-in-out opacity-0 dark:opacity-100 pointer-events-none"
  />
</button>

<script>
  const themeToggleButtons = document.querySelectorAll('.theme-toggle');

  const handleToggleTheme = () => {
    const element = document.documentElement;
    element.classList.toggle('dark');

    const isDark = element.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };

  themeToggleButtons.forEach((btn) => {
    btn.addEventListener('click', handleToggleTheme);
  });
</script>
