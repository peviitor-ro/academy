---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromURL } from '../i18n/utils';

const langauge = getLangFromURL(Astro.url);
---

<!doctype html>
<html lang={langauge}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }

        if (window.matchMedia('(prefers-color-scheme:dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }

      if (window.location.pathname === "/" && !localStorage.getItem("user-language")) {
        const browserLang = navigator.language || navigator.userLanguage;

        if (!browserLang.startsWith("ro")) {
          localStorage.setItem("user-language", "en");
          window.location.href = "/en/"
        } else {
          localStorage.setItem("user-language", "ro");
        }
      }

      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body
    class="min-h-screen bg-beige-500 text-primary-light dark:text-primary-dark dark:bg-dark-500 transition-colors duration-300"
  >
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
